{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "nodenext",
    "rootDir": "./src",
    "moduleResolution": "nodenext",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./build",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "lib": ["ES2023"]
  },
  "include": ["src"]
}
