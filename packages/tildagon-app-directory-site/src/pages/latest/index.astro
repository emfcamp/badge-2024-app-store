---
import Layout from "../../layouts/Layout.astro";
import Alert from "../../components/Alert.astro";
import AppsListing from "../../components/AppsListing.astro";
import { CachedRegistryManager } from "tildagon-app-directory-api";

const data = await CachedRegistryManager.listApps();

const copy = {
  title: "Latest apps",
};
---

<Layout title={copy.title}>
  <main class="col-md-12">
    <a href="/">&#8592; All apps</a>
    <h1>{copy.title}</h1>
    <AppsListing
      data={data.sort(
        (a: { releaseTime: string }, b: { releaseTime: string }) => {
          const dateA = new Date(a.releaseTime);
          const dateB = new Date(b.releaseTime);
          if (dateA === dateB) {
            return 0;
          }
          if (dateA > dateB) {
            return -1;
          } else {
            return 1;
          }
        },
      )}
    />
    <Alert kind="info">
      Can't find your app? <a href="/errors"
        >Check if the app store has a problem parsing it.</a
      >
    </Alert>
  </main>
</Layout>

<style>
  a {
    color: #afc944;
  }
</style>
