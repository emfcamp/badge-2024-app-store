---
import { CachedRegistryManager } from "tildagon-app-directory-api";
import InstallationInstructions from "../../components/InstallationInstructions.astro";
import Alert from "../../components/Alert.astro";
import Layout from "../../layouts/Layout.astro";
import { CategoryColors } from "../../features/categories";

const { code } = Astro.params;

if (!code) {
  return new Response("Bad request", { status: 400 });
}

const result = await CachedRegistryManager.getApp(code);

if (result.type === "failure") {
  return new Response(
    `<html><body><h1>App not found</h1><p>The app "${code}" was not found.</p><a href="/">Back to directory</a></body></html>`,
    { status: 404, headers: { "Content-Type": "text/html" } },
  );
}

const data = result.value;

function urlLooksSuspicious(url: string): boolean {
  return /\[.*?\]/.test(url) || url.includes('username');
}

const showSourceUrlWarning = urlLooksSuspicious(data.manifest.metadata.url);

function capabilityLabel(feature: any): { label: string; filter: string } | null {
  if (feature.type === "Capability") {
    return { label: feature.identifier, filter: `capability=${encodeURIComponent(feature.identifier)}` };
  }
  if (feature.type === "Hexpansion") {
    const { vid, pid, name } = feature.identifier;
    return { label: name || `VID:${vid} PID:${pid}`, filter: `vid=${encodeURIComponent(vid)}&pid=${encodeURIComponent(pid)}` };
  }
  if (typeof feature.type === "string" && feature.type.includes("Frontboard")) {
    return { label: feature.type, filter: `frontboard=${encodeURIComponent(feature.type)}` };
  }
  return null;
}

const capabilities = data.manifest.metadata.capabilities ?? [];
const required = capabilities.filter((c) => c.required);
const optional = capabilities.filter((c) => !c.required);
const provided = data.manifest.metadata.providedCapabilities ?? [];

export async function getStaticPaths() {
  const apps = await CachedRegistryManager.listApps();
  return apps.map((app: any) => ({
    params: { code: app.code },
  }));
}
---

<Layout
  title={`${data.manifest.app.name} — Tildagon App Store`}
  description={`${data.manifest.app.name} by ${data.manifest.metadata.author}. ${data.manifest.metadata.description}`}
  ogType="article"
>
  <main class="col-md-12">
    <h1 class="manifest-name">{data.manifest.app.name}</h1>
    <h2>Description</h2>
    <p>{data.manifest.metadata.description}</p>
    <ul>
      <li><span class="badge">Code: {data.code}</span></li>
      <li>
        <span class="badge"
          >Author: <a
            href={`/author/${encodeURIComponent(data.manifest.metadata.author)}`}
            >{data.manifest.metadata.author}</a
          >
        </span>
      </li>
      <li>
        <ul>
        {data.manifest.app.category.map(category => (<li><span
          class="badge badge-colored"
          style=`--badge-bg: ${CategoryColors[category]}`
          >Category: <a
            href={`/categories/${encodeURIComponent(category)}`}
            >{data.manifest.app.category}</a
          >
        </span></li>))}
        </ul>
      </li>
      <li>
        <span class="badge">Version: {data.manifest.metadata.version}</span>
      </li>
      <li>
        <span class="badge">License: {data.manifest.metadata.license}</span>
      </li>
      <li>
        <span class="badge"
          >Last Updated: {new Date(data.releaseTime).toLocaleDateString()}</span
        >
      </li>
      <li>
        <span class="badge"
          >Source Code Repository: <a href={data.manifest.metadata.url}
            >{data.manifest.metadata.url}</a
          >
        </span>
        {showSourceUrlWarning && (
          <Alert kind="warning">
            This app's source code URL looks like a placeholder (e.g.
            "github.com/username/[app]"). The author should update the{" "}
            <code>url</code> field in their{" "}
            <code>tildagon.toml</code> to point to the actual repository.
          </Alert>
        )}
      </li>
      </ul>
    </li>
  </ul>
  {
    capabilities.length > 0 && (
      <div>
        <h2>Hardware Capabilities</h2>
        {required.length > 0 && (
          <>
            <h3>Required</h3>
            <ul>
              {required.map((c) => {
                const info = capabilityLabel(c.feature);
                return (
                  <li>
                    <span class="badge"
                      >{info?.filter ? (
                        <a href={`/?${info.filter}`}>{info.label}</a>
                      ) : (
                        info?.label ?? "Unknown"
                      )}</span
                    >
                  </li>
                );
              })}
            </ul>
          </>
        )}
        {optional.length > 0 && (
          <>
            <h3>Optional</h3>
            <ul>
              {optional.map((c) => {
                const info = capabilityLabel(c.feature);
                return (
                  <li>
                    <span class="badge"
                      >{info?.filter ? (
                        <a href={`/?${info.filter}`}>{info.label}</a>
                      ) : (
                        info?.label ?? "Unknown"
                      )}</span
                    >
                  </li>
                );
              })}
            </ul>
          </>
        )}
      </div>
    )
  }
  {
    provided.length > 0 && (
      <div>
        <h2>Provided Capabilities</h2>
        <ul>
          {provided.map((p) => (
            <li>
              <span class="badge">{p.capability.identifier}</span>
            </li>
          ))}
        </ul>
      </div>
    )
  }
  <h2>Try it out</h2>
    <a class="btn btn-primary emulator-btn"
      href={`https://emulator.badge.emfcamp.org/#${data.manifest.app.category[0]}/${data.manifest.app.name}`}
      target="_blank">
      Run app in web emulator
    </a>
    <h2>Installation</h2>
    <p>
      To install {data.manifest.app.name} on your badge, launch the App Store app
      and select "CodeInstall". Use the buttons as shown to enter the app code.
    </p>
    <InstallationInstructions code={data.code} />
  </main>

  <style>
    a:hover {
      color: #afc944;
    }

    dd {
      margin-bottom: 8px;
    }

    .emulator-btn {
      display: inline-block;
      margin-bottom: 1em;
    }

    .emulator-btn:hover {
      color: #fff;
    }
  </style>
</Layout>
