---
import type { GetStaticPaths } from "astro";
import Layout from "../../layouts/Layout.astro";
import AppsListing from "../../components/AppsListing.astro";
import Alert from "../../components/Alert.astro";
import { CachedRegistryManager } from "tildagon-app-directory-core";

let { author } = Astro.params;
author = decodeURIComponent(author!);

const data = await CachedRegistryManager.listApps();

export const getStaticPaths = (async () => {
  const data = await CachedRegistryManager.listApps();

  const authors = new Set<string>(
    data.map((app: any) => app.manifest.metadata.author),
  );

  return Array.from(authors).map((author) => ({
    params: { author },
  }));
}) satisfies GetStaticPaths;
---

<Layout title={`Apps by ${author} — Tildagon App Store`} description={`Browse apps by ${author} on the Tildagon App Store`}>
  <main class="col-md-12">
    <a href="/">&#8592; All apps</a>
    <h1>Apps by: {author}</h1>
    <AppsListing
      data={data.filter((app: any) => app.manifest.metadata.author === author)}
    />
    <Alert kind="info">
      Can't find your app? <a href="/errors"
        >Check if the app store has a problem parsing it.</a
      >
    </Alert>
  </main>
</Layout>

<style>
  .apps {
    display: flex;
    flex-direction: row;
    justify-content: space-evenly;
    gap: 1rem;
    margin: none;
    padding: none;
    flex-wrap: wrap;
  }

  a {
    color: #afc944;
  }
</style>
