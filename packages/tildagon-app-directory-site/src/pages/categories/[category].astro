---
import type { GetStaticPaths } from "astro";
import Layout from "../../layouts/Layout.astro";
import Alert from "../../components/Alert.astro";
import AppsListing from "../../components/AppsListing.astro";
import { CachedRegistryManager } from "tildagon-app-directory-core";
import { TildagonAppCategory } from "tildagon-app";
import { CategoryColors } from "../../features/categories";

const data = await CachedRegistryManager.listApps();

const { category } = Astro.params;

export const getStaticPaths = (async () => {
  return Array.from(TildagonAppCategory.options).map((category) => ({
    params: { category },
  }));
}) satisfies GetStaticPaths;

const categoryDescriptionCopy: Record<TildagonAppCategory, string> = {
  Badge: "Displays the name of the user",
  Music: "Music related apps",
  Media: "Video, social, news, canvas and sculpture",
  Apps: "General purpose Tildagon apps",
  Games: "DOOM probably",
  Background: "Visualisations that run behind the badge menu",
  Pattern: "Colors and animations for the Tildagon's RGB LEDs",
};

const parsed = TildagonAppCategory.safeParse(category);
if (!parsed.success) {
  return new Response("Category not found", { status: 404 });
}

const cat = parsed.data;
---

<Layout title={`${cat} apps — Tildagon App Store`} description={`Browse ${cat} apps on the Tildagon App Store`}>
  <main class="col-md-12" style=`--badge-bg: ${CategoryColors[cat]}`>
    <a href="/">&#8592; All apps</a>
    <h1>{cat}</h1>
    <p>{categoryDescriptionCopy[cat]}</p>
    <hr />
    <AppsListing
      data={data.filter((app: any) =>
        app.manifest.app.category.includes(cat),
      )}
    />
    <Alert kind="info">
      Can't find your app? <a href="/errors"
        >Check if the app store has a problem parsing it.</a
      >
    </Alert>
  </main>
</Layout>

<style>
  .category-nav {
    display: flex;
    gap: 16px;
    padding: 8px 16px;

    a {
      font-size: 1.8em;
    }
  }

  a {
    color: #afc944;
  }

  hr {
    border-color: var(--badge-bg);
    border-width: 8px;
  }
</style>
