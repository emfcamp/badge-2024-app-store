---
import type { GetStaticPaths } from "astro";
import Layout from "../../layouts/Layout.astro";
import Alert from "../../components/Alert.astro";
import AppsListing from "../../components/AppsListing.astro";
import AppCategoryNav from "../../components/AppCategoryNav.astro";
import { CachedRegistryManager } from "tildagon-app-directory-api";
import { TildagonAppCategory } from "tildagon-app";
import type { TildagonAppManifest } from "tildagon-app";
import { CategoryColors } from "../../features/categories";

const data = await CachedRegistryManager.listApps();

const { category: param_category } = Astro.params;

if (!param_category) {
  throw new Error("A category must be provided");
}

if (TildagonAppCategory.safeParse(param_category).error) {
  throw new Error(`${param_category} is not a valid category`);
}

const category = TildagonAppCategory.parse(param_category);

export const getStaticPaths = (async () => {
  const data = await CachedRegistryManager.listApps();

  const categories = new Set<string>(
    data.map((app: any) => app.manifest.app.category),
  );

  return Array.from(categories).map((category) => ({
    params: { category },
  }));
}) satisfies GetStaticPaths;

const categoryDescriptionCopy: Record<
  TildagonAppManifest["app"]["category"],
  string
> = {
  Badge: "Displays the name of the user",
  Music: "Music related apps",
  Media: "Video, social, news, canvas and sculpture",
  Apps: "General purpose Tildagon apps",
  Games: "DOOM probably",
  Background: "Visualisations that run behind the badge menu",
  Pattern: "Colors and animations for the Tildagon's RGB LEDs",
};
---

<Layout title={category}>
  <AppCategoryNav data={data} />
  <main class="col-md-12" style=`--badge-bg: ${CategoryColors[category]}`>
    <h1>{category}</h1>
    <p>{categoryDescriptionCopy[category]}</p>
    <hr />
    <AppsListing
      data={data.filter((app: any) => app.manifest.app.category === category)}
    />
    <Alert kind="info">
      Can't find your app? <a href="/errors"
        >Check if the app store has a problem parsing it.</a
      >
    </Alert>
  </main>
</Layout>

<style>
  .category-nav {
    display: flex;
    gap: 16px;
    padding: 8px 16px;

    a {
      font-size: 1.8em;
    }
  }

  hr {
    border-color: var(--badge-bg);
    border-width: 8px;
  }
</style>
