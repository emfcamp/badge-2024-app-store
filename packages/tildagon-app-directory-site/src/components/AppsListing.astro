---
import type { TildagonAppRelease } from "tildagon-app";
import AppCard from "./AppCard.astro";

type Props = {
  data: TildagonAppRelease[];
};

const { data } = Astro.props;
---

<section role="list" class="apps">
  {data.map((release) => <AppCard release={release} />)}
</section>

<style>
  .apps {
    display: flex;
    flex-direction: row;
    justify-content: space-evenly;
    gap: 1rem;
    margin: none;
    padding: none;
    flex-wrap: wrap;
  }
</style>
