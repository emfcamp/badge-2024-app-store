---
import { TildagonAppCategory } from "tildagon-app";
---

<nav class="category-nav">
  {
    Array.from(TildagonAppCategory.options)
      .sort()
      .map((category) => <a href={`/categories/${category}`}>{category}</a>)
  }
  <a href="/capabilities/" class="capabilities-link">Capabilities</a>
</nav>
<style>
  .category-nav {
    display: flex;
    gap: 16px;
    padding: 8px 16px;
    flex-wrap: wrap;

    a {
      font-size: 1.8em;
      color: #fff;
      font-family: Raleway, "Helvetica Neue", Helvetica, Arial, sans-serif;
    }
  }
</style>
