---
import { CategoryColors } from "../features/categories/index";
import type { TildagonAppRelease } from "tildagon-app";

type Props = {
  release: TildagonAppRelease;
};

const { release } = Astro.props;

const { description, author } = release.manifest.metadata;
const code = release.code;
const { name, category } = release.manifest.app;
console.log(category);
---

<a href={`${import.meta.env.BASE_URL}apps/${code}`}>
  <article style={{ "--badge-bg": CategoryColors[category[0]!] }}>
    <div class="panel-heading">
      <h4>{name}</h4>
    </div>
    <div class="panel-body">
      <p>
        {description}
      </p>
      <span class="badge"><b>Author:</b> {author}</span>
      {
        category.map((category) => (
          <span class="badge badge-colored">
            <b>Category:</b> {category}
          </span>
        ))
      }
    </div>
  </article>
</a>

<style>
  a {
    display: block;
    flex: 1 1 400px;
    text-decoration-color: #528329;

    transition: all 0.15s ease;
  }

  a:hover,
  a:focus {
    text-decoration: none;
    position: relative;
    transform: translate(-2px, -2px);

    .panel-heading h4 {
      text-decoration: underline;
      text-decoration-color: var(--badge-bg, #528329);
      text-decoration-thickness: 2px;
    }
  }

  article {
    padding: none;
    background-color: #cfccc0;
    color: #1e1e1e;
    border: 1px solid #528329;
    border-radius: 0.5rem;
    margin-bottom: 1rem;

    h1,
    h2,
    h3,
    h4,
    h5,
    h6 {
      color: #1e1e1e;
    }
  }

  .panel-heading {
    margin: none;
    background-color: #d6c8a0;
    border-bottom: 4px solid var(--badge-bg);
  }
</style>
