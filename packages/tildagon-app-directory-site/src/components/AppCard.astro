---
import { TildagonAppCategory } from "tildagon-app";
import { CategoryColors } from "../features/categories/index";

interface Props {
  title: string;
  description: string;
  owner: string;
  code: string;
  category?: string;
}

const {
  title,
  description,
  owner,
  code,
  category: param_category,
} = Astro.props;

const category = TildagonAppCategory.parse(param_category);
---

<a href={`${import.meta.env.BASE_URL}apps/${code}`}>
  <article style={{ "--badge-bg": CategoryColors[category] }}>
    <div class="panel-heading">
      <h4>{title}</h4>
    </div>
    <div class="panel-body">
      <p>
        {description}
      </p>
      <span class="badge"><b>Owner:</b> {owner}</span>
      {
        category && (
          <span class="badge badge-colored">
            <b>Category:</b> {category}
          </span>
        )
      }
    </div>
  </article>
</a>

<style>
  a {
    display: block;
    flex: 1 1 400px;
    text-decoration-color: #528329;

    transition: all 0.15s ease;
  }

  a:hover,
  a:focus {
    text-decoration: none;
    position: relative;
    transform: translate(-2px, -2px);

    .panel-heading h4 {
      text-decoration: underline;
      text-decoration-color: var(--badge-bg, #528329);
      text-decoration-thickness: 2px;
    }
  }

  article {
    padding: none;
    background-color: #cfccc0;
    color: #1e1e1e;
    border: 1px solid #528329;
    border-radius: 0.5rem;
    margin-bottom: 1rem;

    h1,
    h2,
    h3,
    h4,
    h5,
    h6 {
      color: #1e1e1e;
    }
  }

  .panel-heading {
    margin: none;
    background-color: #d6c8a0;
    border-bottom: 4px solid var(--badge-bg);
  }
</style>
