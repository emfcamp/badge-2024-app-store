{
  "name": "openapi-spec",
  "module": "index.ts",
  "types": "schema.d.ts",
  "type": "module",
  "scripts": {
    "generate:spec": "mkdir -p build & npx @redocly/cli bundle spec/openapi.yaml > build/spec.yaml",
    "generate:types": "npx openapi-typescript build/spec.yaml -o build/schema.d.ts",
    "check-types": "tsc --noEmit",
    "build": "tsc",
    "lint": "npx -p @seriousme/openapi-schema-validator spec/openapi.yaml"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@redocly/cli": "2.30.4",
    "openapi-typescript": "^7.10.1"
  },
  "private": "true",
  "scarfSettings": {
    "enabled": false
  }
}
